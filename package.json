{
	"name": "high-order-type-monad-checker",
	"version": "1.0.0",
	"description": "Type-level monad-style checker on TypeScript content graphs",
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js"
		}
	},
	"bin": {
		"check-monad": "./dist/cli/check-monad.js"
	},
	"directories": {
		"doc": "docs",
		"test": "test"
	},
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"build": "rm -rf dist/* && tsc -p tsconfig.build.json",
		"prepublishOnly": "npm run build",
		"test": "npm run --silent typecheck && node --test test/*.test.ts && npm run --silent format:check",
		"typecheck": "tsgo -p tsconfig.json --noEmit",
		"check-external": "PATH=\"$(pwd)/cli:$(pwd)/.external/repo/node_modules/.bin:$PATH\" eval \"cd .external/repo && $(jq -r '.scripts.monadcheck' .external/repo/package.json)\"",
		"check-external1": "npm run --silent check-external -- -1"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vadzim/high-order-type-monad-checker.git"
	},
	"keywords": [
		"typescript",
		"monad",
		"type-checker",
		"static-analysis"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"core-js": "^3.49.0",
		"fast-glob": "^3.3.3",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@types/core-js": "^2.5.8",
		"@types/node": "^25.6.0",
		"@typescript/native-preview": "^7.0.0-dev.20260414.1",
		"prettier": "^3.8.2",
		"tsx": "^4.21.0"
	}
}
