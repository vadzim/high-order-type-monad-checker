{
	"name": "monad-checker",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"directories": {
		"doc": "docs",
		"test": "test"
	},
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "npm run --silent typecheck && node --test test/*.test.ts",
		"check-external": "node cli/check-monad.ts --snippet-lines 5:5 '../jsql/src/parser/**/*.ts' '../jsql/src/engine/**/*.ts' --monad ../jsql/src/parser/sql-tokens.ts TokensList:ParseSqlTokens:PeekToken:SkipToken",
		"check-external-1": "node cli/check-monad.ts --snippet-lines 5:5 '../jsql/src/parser/sql-tokens.ts' --monad ../jsql/src/parser/sql-tokens.ts TokensList:ParseSqlTokens:PeekToken:SkipToken",
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsgo -p tsconfig.json --noEmit"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "module",
	"dependencies": {
		"core-js": "^3.49.0",
		"fast-glob": "^3.3.3",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@types/core-js": "^2.5.8",
		"@types/node": "^25.6.0",
		"@typescript/native-preview": "^7.0.0-dev.20260414.1",
		"prettier": "^3.8.2"
	}
}
